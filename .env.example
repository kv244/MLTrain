# Server Bindings
APP_HOST=127.0.0.1
APP_PORT=5000
FLASK_DEBUG=False

# Rate Limiting
# Use a semicolon to separate multiple limits, e.g. "500 per day;200 per hour"
RATE_LIMIT="1000 per day;200 per hour;100 per minute"
LIMITER_STORAGE_URI=memory://

# Data & Telemetry Paths
RESULTS_LOG_PATH=game_results.csv
TELEMETRY_LOG_PATH=telemetry.csv

# Telemetry & Analytics
# GCP_PROJECT_ID: Required for BigQuery player analytics tracking (optional for local dev).
GCP_PROJECT_ID=your-gcp-project-id

# AI Integration (Dynamic Environment & Move Assessment)
# GEMINI_API_KEY: Required for generating weekly backgrounds (using Imagen 4.0), move assessment comments, and UI localisation.
GEMINI_API_KEY=your-gemini-api-key
