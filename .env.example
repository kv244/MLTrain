# Server Bindings
APP_HOST=127.0.0.1
APP_PORT=5000
FLASK_DEBUG=False

# Rate Limiting
# Use a semicolon to separate multiple limits, e.g. "500 per day;200 per hour"
RATE_LIMIT="1000 per day;200 per hour;100 per minute"
LIMITER_STORAGE_URI=memory://

# Data & Telemetry Paths
RESULTS_LOG_PATH=game_results.csv
TELEMETRY_LOG_PATH=telemetry.csv

# AI Integration (Dynamic Environment)
# GCP_PROJECT_ID: Required for Vertex AI Imagen background generation.
GCP_PROJECT_ID=your-gcp-project-id
# GEMINI_API_KEY: Required for background prompt generation and move assessment.
GEMINI_API_KEY=your-gemini-api-key

# Note: vertexai.init() (used in background_manager.py) requires 
# Application Default Credentials (ADC).
# On a GCP VM, this works automatically via the attached service account.
# For local development, run: gcloud auth application-default login
